# VoLo Engine API Keys
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Anthropic API Key (for Claude Haiku, Sonnet, Opus)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Refiant API Key (for qwen-rfnt)
REFIANT_API_KEY=sk_live_...

# ── Google Drive Integration (per-user OAuth) ────────────────────────────────
# Each user signs in with their own Google account. These three secrets
# identify the app to Google and protect stored refresh tokens at rest.
#
# 1. GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET
#    Created in Google Cloud Console → APIs & Services → Credentials →
#    Create Credentials → OAuth client ID (Web application). Authorized
#    redirect URIs must include this app's /api/drive/oauth/callback path.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
#
# 2. GOOGLE_OAUTH_REDIRECT_URI (optional)
#    Defaults to scheme://host/api/drive/oauth/callback derived from the
#    incoming request, which works on Replit and localhost. Override only
#    if you need to force a specific URL (e.g., behind an unusual proxy).
# GOOGLE_OAUTH_REDIRECT_URI=https://vo-lo-analysis-tool.replit.app/api/drive/oauth/callback
#
# 3. GOOGLE_TOKEN_ENCRYPTION_KEY
#    Fernet key used to encrypt each user's stored refresh token. Generate
#    once with:
#      python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#    Keep this stable across deploys — rotating it invalidates every stored
#    Drive connection (users will just need to reconnect).
GOOGLE_TOKEN_ENCRYPTION_KEY=

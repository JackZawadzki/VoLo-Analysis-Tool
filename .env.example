# ─────────────────────────────────────────────────────────────────────────────
#  VoLo Analysis Tool — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in the values:
#     cp .env.example .env
#
# Anything left blank = the corresponding feature is disabled. The app boots
# fine without optional keys; it will only refuse a specific request if the
# user actually triggers a feature whose key is missing.


# ═════════════════════════════════════════════════════════════════════════════
#  AI MODELS  ────  REQUIRED for any AI feature (IC memo, DDR, extraction)
# ═════════════════════════════════════════════════════════════════════════════

# Anthropic — used by default for: pitch-deck extraction, deal chat, dev
# agent, IC memo generation, DDR research, banker financial-model parsing.
# Get a key at https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Refiant (Qwen) — only used when the user explicitly selects a "qwen-*"
# model in their Model Preferences. Routes through the OpenAI-compatible
# Refiant endpoint at https://api.refiant.ai/v1.
#
# Drop your new Refiant key in here. Setting this DOES NOT change which
# model any feature uses by default — Claude stays the default for
# everything until a user picks "Refiant qwen-rfnt" in the model
# preferences UI.
REFIANT_API_KEY=


# ═════════════════════════════════════════════════════════════════════════════
#  AUTH & SESSIONS  ────  REQUIRED
# ═════════════════════════════════════════════════════════════════════════════

# JWT signing key for user sessions (login tokens, email verification,
# password reset). Use any long random string. Rotating it logs everyone
# out — keep it stable across deploys.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Comma-separated list of email domains allowed to register (default
# blocks everything but voloearth.com). Leave unset to use the default.
# AUTH_ALLOWED_DOMAINS=voloearth.com,partnerfirm.com


# ═════════════════════════════════════════════════════════════════════════════
#  EMAIL (verification + password reset)  ────  REQUIRED for registration
# ═════════════════════════════════════════════════════════════════════════════

# Option A — Gmail with an app password (16-char password from Google
# Account → Security → 2-Step Verification → App passwords).
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Option B — Resend (alternative provider; only used if GMAIL_USER is empty)
# RESEND_API_KEY=

# "From" address shown to users. Defaults to GMAIL_USER if unset.
# EMAIL_FROM="VoLo Earth Ventures <noreply@voloearth.com>"


# ═════════════════════════════════════════════════════════════════════════════
#  GOOGLE DRIVE INTEGRATION  ────  optional (per-user OAuth)
# ═════════════════════════════════════════════════════════════════════════════
#
# Each user signs in with their own Google account; these three secrets
# identify the app to Google and protect stored refresh tokens.

# Created in Google Cloud Console → APIs & Services → Credentials →
# Create Credentials → OAuth client ID (Web application). Authorized
# redirect URIs must include this app's /api/drive/oauth/callback path.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Defaults to scheme://host/api/drive/oauth/callback derived from the
# incoming request (works on Replit + localhost). Override only if you
# need to force a specific URL behind a proxy.
# GOOGLE_OAUTH_REDIRECT_URI=https://vo-lo-analysis-tool.replit.app/api/drive/oauth/callback

# Fernet key for encrypting each user's stored refresh token. Generate
# once with:
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep stable across deploys — rotating it disconnects every user.
GOOGLE_TOKEN_ENCRYPTION_KEY=


# ═════════════════════════════════════════════════════════════════════════════
#  DEPLOYMENT PERSISTENCE  ────  optional but RECOMMENDED on Replit
# ═════════════════════════════════════════════════════════════════════════════

# Replit Reserved-VM redeploys wipe the source tree. Pin the SQLite DB
# and uploads outside the source tree so they survive redeploys.
# VOLO_DB_PATH=/home/runner/.volo/rvm.db
# VOLO_UPLOADS_DIR=/home/runner/.volo/uploads

# Postgres alternative — set DATABASE_URL to switch from SQLite. Format:
#     postgresql://user:pass@host:5432/dbname
# DATABASE_URL=

# Public URL of the deploy, used in email links. Leave unset to derive
# from request host.
# APP_URL=https://vo-lo-analysis-tool.replit.app


# ═════════════════════════════════════════════════════════════════════════════
#  FEATURE FLAGS  ────  optional
# ═════════════════════════════════════════════════════════════════════════════

# Set to "0" to fall back to the legacy financial-model extractor instead
# of the newer single-source-of-truth one.
# VOLO_USE_NEW_EXTRACTOR=1

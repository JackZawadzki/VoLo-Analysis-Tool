modules = ["python-3.11"]
run = "sh start.sh"
entrypoint = "app/main.py"

[nix]
channel = "stable-24_05"

[env]
PYTHONUNBUFFERED = "1"
PYTHONDONTWRITEBYTECODE = "1"

[deployment]
run = ["sh", "-c", "pip install -r requirements.txt && uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000} --workers 2"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8000
externalPort = 80
